---
interface Props {
  type: "website" | "organization" | "localBusiness" | "article" | "faq" | "service";
  data: Record<string, unknown>;
}

import { siteConfig } from "../../config/site";
import { companyConfig } from "../../config/company";

type StructuredDataProps = Props["data"];

const { type, data } = Astro.props;

const logoUrl = new URL("/bitdoze_logo_better.svg", siteConfig.url).toString();
const defaultImageUrl = new URL(siteConfig.ogImage || "/images/og-image.svg", siteConfig.url).toString();
const localBusinessImageUrl = new URL("/images/welcome-image.jpg", siteConfig.url).toString();

function getAuthorName(value: StructuredDataProps[keyof StructuredDataProps]) {
  if (typeof value === "string" && value.trim().length > 0) {
    return value;
  }

  if (
    typeof value === "object" &&
    value !== null &&
    "name" in value &&
    typeof value.name === "string" &&
    value.name.trim().length > 0
  ) {
    return value.name;
  }

  return "BitDoze";
}

let structuredData: Record<string, unknown>;

// Base data objects for different structured data types
const websiteData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.name,
  url: siteConfig.url,
  description: siteConfig.description,
  ...data
};

const organizationData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: companyConfig.name,
  url: siteConfig.url,
  logo: data.logo || logoUrl,
  sameAs: companyConfig.socialMedia.map((social) => social.url),
  contactPoint: {
    "@type": "ContactPoint",
    telephone: companyConfig.contact.phone,
    email: companyConfig.contact.email,
    contactType: "customer service"
  },
  ...data
};

const localBusinessData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: companyConfig.name,
  url: siteConfig.url,
  image: data.image || localBusinessImageUrl,
  telephone: companyConfig.contact.phone,
  email: companyConfig.contact.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: companyConfig.contact.address.street,
    addressLocality: companyConfig.contact.address.city,
    addressRegion: companyConfig.contact.address.state,
    postalCode: companyConfig.contact.address.zip,
    addressCountry: companyConfig.contact.address.country
  },
  ...data
};

const articleData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title || "BitDoze",
  image: data.image || defaultImageUrl,
  author: {
    "@type": "Person",
    name: getAuthorName(data.author)
  },
  publisher: {
    "@type": "Organization",
    name: companyConfig.name,
    logo: {
      "@type": "ImageObject",
      url: logoUrl
    }
  },
  datePublished: data.datePublished || new Date().toISOString(),
  dateModified: data.dateModified || new Date().toISOString(),
  ...data
};

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity:
    (Array.isArray(data.questions)
      ? data.questions.map((question) => {
          const item =
            typeof question === "object" && question !== null ? question : {};

          return {
            "@type": "Question",
            name: "question" in item ? item.question : "",
            acceptedAnswer: {
              "@type": "Answer",
              text: "answer" in item ? item.answer : "",
            },
          };
        })
      : []),
  ...data
};

const serviceData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: data.name || "Servicii BitDoze",
  provider: {
    "@type": "Organization",
    name: companyConfig.name
  },
  description: data.description || siteConfig.description,
  ...data
};

// Select the appropriate structured data based on type
switch (type) {
  case "website":
    structuredData = websiteData;
    break;
  case "organization":
    structuredData = organizationData;
    break;
  case "localBusiness":
    structuredData = localBusinessData;
    break;
  case "article":
    structuredData = articleData;
    break;
  case "faq":
    structuredData = faqData;
    break;
  case "service":
    structuredData = serviceData;
    break;
  default:
    structuredData = websiteData;
}
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
