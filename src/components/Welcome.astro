---
interface Props {
  title?: string;
  subtitle?: string;
  ctas?: {
    primary: {
      text: string;
      link: string;
    };
    secondary?: {
      text: string;
      link: string;
    };
  };
}

const {
  title = "Construim Soluții Digitale pentru Afacerea Ta",
  subtitle = "Suntem o agenție de dezvoltare web dedicată creării de site-uri rapide, optimizate SEO și aplicații web performante care te ajută să-ți atingi obiectivele de business.",
  ctas = {
    primary: { text: "Vezi Serviciile", link: "/servicii" },
    secondary: { text: "Contactează-ne", link: "/contact" },
  }
} = Astro.props;
---

<section class="welcome-hero section-padding">
  <div class="container container-lg">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Agenție Web Design & SEO
      </div>
      <h1 class="hero-title">
        {title}
      </h1>
      <p class="hero-subtitle">
        {subtitle}
      </p>
      
      <div class="hero-actions">
        {ctas.primary && (
          <a href={ctas.primary.link} class="btn btn-primary btn-lg">
            {ctas.primary.text}
          </a>
        )}
        {ctas.secondary && (
          <a href={ctas.secondary.link} class="btn btn-outline btn-lg">
            {ctas.secondary.text}
          </a>
        )}
      </div>
    </div>
  </div>

  <style>
    .welcome-hero {
      background-color: var(--color-background);
      padding-top: 6rem;
      padding-bottom: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    :global(.dark) .welcome-hero {
      background-color: var(--color-dark-background);
    }

    .hero-content {
      max-width: 56rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 1rem;
      background: rgba(var(--color-text-rgb), 0.04);
      color: var(--color-text);
      border-radius: 9999px;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid rgba(var(--color-text-rgb), 0.08);
      margin-bottom: 0.5rem;
    }

    :global(.dark) .hero-badge {
      background: rgba(255, 255, 255, 0.05);
      color: var(--color-dark-text);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .badge-dot {
      width: 6px;
      height: 6px;
      background-color: var(--color-primary);
      border-radius: 50%;
    }

    .hero-title {
      font-size: clamp(2.5rem, 6vw, 4.25rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--color-text);
      margin: 0;
    }

    :global(.dark) .hero-title {
      color: var(--color-dark-text);
    }

    .hero-subtitle {
      font-size: clamp(1.1rem, 2.5vw, 1.25rem);
      color: var(--color-text-light);
      line-height: 1.6;
      max-width: 44rem;
      margin: 0;
    }

    :global(.dark) .hero-subtitle {
      color: var(--color-dark-text-light);
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      margin-top: 1rem;
    }

    @media (max-width: 640px) {
      .welcome-hero {
        padding-top: 4rem;
      }
      
      .hero-actions {
        flex-direction: column;
        width: 100%;
        max-width: 20rem;
      }
      
      .hero-actions .btn {
        width: 100%;
      }
    }
  </style>
</section>
