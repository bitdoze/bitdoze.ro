---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  icon: string;
  link?: string;
  ctaText?: string;
  index?: number;
  badge?: {
    text: string;
    type?: "popular" | "recommended" | "new";
    icon?: string;
  };
  price?: string;
}

const {
  title,
  description,
  icon,
  link,
  ctaText = "Află mai multe",
  index = 0,
  badge,
  price,
} = Astro.props;

---

<div class="service-card-minimal">
  <div class="card-header">
    <div class="icon-wrapper">
      <Icon name={icon} class="service-icon" />
    </div>
    {badge && (
      <span class="card-badge">
        {badge.text}
      </span>
    )}
  </div>

  <div class="card-body">
    <h3 class="service-title">{title}</h3>
    <p class="service-description">{description}</p>
  </div>

  <div class="card-footer">
    {price && (
      <span class="price-amount">{price}</span>
    )}
    
    {link ? (
      <a href={link} class="card-cta">
        {ctaText} <Icon name="mdi:arrow-right" class="cta-icon" />
      </a>
    ) : (
      <span class="card-cta">
        {ctaText} <Icon name="mdi:arrow-right" class="cta-icon" />
      </span>
    )}
  </div>
</div>

<style>
  .service-card-minimal {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 2rem;
    background: var(--color-background);
    border: 1px solid rgba(var(--color-text-rgb), 0.08);
    border-radius: 1rem;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .service-card-minimal:hover {
    border-color: rgba(var(--color-primary-rgb), 0.3);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  :global(.dark) .service-card-minimal {
    background: var(--color-dark-background);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global(.dark) .service-card-minimal:hover {
    border-color: rgba(var(--color-primary-rgb), 0.4);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: rgba(var(--color-text-rgb), 0.04);
    color: var(--color-primary);
  }

  :global(.dark) .icon-wrapper {
    background: rgba(255, 255, 255, 0.05);
  }

  .service-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .card-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(var(--color-primary-rgb), 0.1);
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }

  .card-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  :global(.dark) .service-title {
    color: var(--color-dark-text);
  }

  .service-description {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  :global(.dark) .service-description {
    color: var(--color-dark-text-light);
  }

  .card-footer {
    margin-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .price-amount {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  :global(.dark) .price-amount {
    color: var(--color-dark-text);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .card-cta:hover {
    color: var(--color-primary-dark);
  }

  .cta-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .card-cta:hover .cta-icon {
    transform: translateX(4px);
  }
</style>
