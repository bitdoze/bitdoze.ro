---
// This is the parent Tabs component that manages the tab state
---

<div class="not-prose tabs-container w-full my-6">
  <div
    class="tab-list flex flex-wrap border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 rounded-t-lg"
    role="tablist"
  >
    <!-- Tab buttons will be injected here by client-side script -->
  </div>
  <div
    class="tab-panels bg-white dark:bg-gray-900 rounded-b-lg border border-t-0 border-gray-200 dark:border-gray-700"
  >
    <slot />
  </div>
</div>

<script>
  (() => {
    const ACTIVE_CLASSES = [
      "active",
      "bg-white",
      "dark:bg-gray-900",
      "border-b-2",
      "border-blue-600",
      "text-blue-600",
      "dark:text-blue-500",
      "dark:border-blue-500",
      "font-semibold",
    ];
    const INACTIVE_CLASSES = [
      "bg-gray-50",
      "dark:bg-gray-800",
      "text-gray-600",
      "hover:text-gray-800",
      "hover:bg-gray-100",
      "dark:text-gray-400",
      "dark:hover:text-gray-200",
      "dark:hover:bg-gray-700",
    ];
    const win = window as Window & { __bitdozeTabsBooted?: boolean };

    const selectTab = (
      buttons: HTMLButtonElement[],
      panels: HTMLElement[],
      nextIndex: number,
      focusButton = false,
    ) => {
      buttons.forEach((button, index) => {
        const selected = index === nextIndex;
        button.setAttribute("aria-selected", String(selected));
        button.setAttribute("tabindex", selected ? "0" : "-1");
        button.classList.toggle("active", selected);
        button.classList.remove(...(selected ? INACTIVE_CLASSES : ACTIVE_CLASSES));
        button.classList.add(...(selected ? ACTIVE_CLASSES : INACTIVE_CLASSES));
        if (focusButton && selected) {
          button.focus();
        }
      });

      panels.forEach((panel, index) => {
        const selected = index === nextIndex;
        panel.hidden = !selected;
        panel.setAttribute("tabindex", selected ? "0" : "-1");
      });
    };

    function initTabs() {
      document.querySelectorAll(".tabs-container").forEach((container, containerIndex) => {
        const tabList = container.querySelector(".tab-list");
        const tabPanels = Array.from(
          container.querySelectorAll<HTMLElement>(".tab-panel"),
        );

        if (!(tabList instanceof HTMLElement) || tabPanels.length === 0) return;

        tabList.innerHTML = "";
        const buttons: HTMLButtonElement[] = [];

        tabPanels.forEach((panel, panelIndex) => {
          if (!(panel instanceof HTMLElement)) {
            return;
          }

          const tabName = panel.getAttribute("data-name");
          if (!tabName) {
            return;
          }

          const slug = tabName
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "");
          const tabId = `tabs-${containerIndex}-${slug || panelIndex}-tab`;
          const panelId = `tabs-${containerIndex}-${slug || panelIndex}-panel`;

          panel.id = panelId;
          panel.setAttribute("aria-labelledby", tabId);

          const button = document.createElement("button");
          button.type = "button";
          button.id = tabId;
          button.className =
            "tab-button px-4 sm:px-6 py-3 font-medium text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset transition-all duration-200";
          button.setAttribute("role", "tab");
          button.setAttribute("aria-controls", panelId);
          button.textContent = tabName;
          button.addEventListener("click", () => selectTab(buttons, tabPanels, panelIndex), {
            once: false,
          });

          buttons.push(button);
          tabList.appendChild(button);
        });

        tabList.onkeydown = (event) => {
          if (!(event instanceof KeyboardEvent)) {
            return;
          }

          const currentIndex = buttons.findIndex(
            (button) => button.getAttribute("aria-selected") === "true",
          );
          if (currentIndex === -1) {
            return;
          }

          let nextIndex = currentIndex;

          if (event.key === "ArrowRight" || event.key === "ArrowDown") {
            nextIndex = (currentIndex + 1) % buttons.length;
          } else if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
            nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
          } else if (event.key === "Home") {
            nextIndex = 0;
          } else if (event.key === "End") {
            nextIndex = buttons.length - 1;
          } else {
            return;
          }

          event.preventDefault();
          selectTab(buttons, tabPanels, nextIndex, true);
        };

        selectTab(buttons, tabPanels, 0);
      });
    }

    if (!win.__bitdozeTabsBooted) {
      win.__bitdozeTabsBooted = true;
      document.addEventListener("astro:page-load", initTabs);
      document.addEventListener("astro:after-swap", initTabs);
      document.addEventListener("DOMContentLoaded", initTabs, { once: true });
    }

    initTabs();
  })();
</script>

<style>
  .tabs-container {
    width: 100%;
    max-width: none;
  }

  .tab-button {
    transition: all 0.2s ease-in-out;
    border-radius: 0.5rem 0.5rem 0 0;
    position: relative;
    z-index: 1;
  }

  .tab-button.active {
    font-weight: 600;
    margin-bottom: -1px;
  }

  .tab-button:first-child {
    border-top-left-radius: 0.5rem;
  }

  .tab-button:last-child {
    border-top-right-radius: 0.5rem;
  }

  .tab-panels {
    width: 100%;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .tab-button {
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
    }
  }
</style>
