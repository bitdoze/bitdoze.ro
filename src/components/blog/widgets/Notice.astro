---
export interface Props {
  type?: "info" | "success" | "warning" | "error";
  title?: string;
}

const { type = "info", title } = Astro.props;

const typeStyles = {
  info: {
    icon: "notice-icon--info",
    tone: "notice--info",
  },
  success: {
    icon: "notice-icon--success",
    tone: "notice--success",
  },
  warning: {
    icon: "notice-icon--warning",
    tone: "notice--warning",
  },
  error: {
    icon: "notice-icon--error",
    tone: "notice--error",
  },
};

const icons = {
  info: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
  </svg>`,
  success: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
  </svg>`,
  warning: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
  </svg>`,
  error: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
  </svg>`,
};
---

<div
  class={`not-prose notice ${typeStyles[type].tone}`}
>
  {
    title ? (
      <div class="mb-3">
        <div class="flex items-center">
          <div
            class={`shrink-0 mr-3 ${typeStyles[type].icon}`}
            set:html={icons[type]}
          />
          <h3
            class="text-lg sm:text-xl font-semibold notice__title"
          >
            {title}
          </h3>
        </div>
      </div>
    ) : (
      <div class="flex items-start mb-2">
        <div
          class={`shrink-0 mr-3 ${typeStyles[type].icon}`}
          set:html={icons[type]}
        />
      </div>
    )
  }
  <div
    class={`prose prose-lg [&_a]:font-bold max-w-none notice__content ${title ? "pl-8" : ""}`}
  >
    <slot />
  </div>
</div>

<style>
  .notice {
    width: 100%;
    max-width: none;
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(var(--color-text-rgb), 0.08);
    border-left-width: 4px;
    border-radius: 1rem;
    color: var(--color-text);
    box-shadow: 0 14px 28px rgba(var(--color-text-rgb), 0.05);
  }

  .notice--info {
    background: linear-gradient(180deg, rgba(14, 165, 233, 0.08), rgba(var(--color-background-rgb), 0.98));
    border-left-color: #0ea5e9;
  }

  .notice--success {
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.09), rgba(var(--color-background-rgb), 0.98));
    border-left-color: #22c55e;
  }

  .notice--warning {
    background: linear-gradient(180deg, rgba(245, 158, 11, 0.1), rgba(var(--color-background-rgb), 0.98));
    border-left-color: #f59e0b;
  }

  .notice--error {
    background: linear-gradient(180deg, rgba(239, 68, 68, 0.08), rgba(var(--color-background-rgb), 0.98));
    border-left-color: #ef4444;
  }

  .notice-icon--info {
    color: #0284c7;
  }

  .notice-icon--success {
    color: #16a34a;
  }

  .notice-icon--warning {
    color: #d97706;
  }

  .notice-icon--error {
    color: #dc2626;
  }

  .notice__title {
    color: var(--color-text);
  }

  .notice__content {
    color: var(--color-text);
  }

  .notice a {
    font-weight: bold;
    color: var(--color-primary);
  }

  /* Ensure proper spacing and typography */
  .notice :global(p) {
    margin-bottom: 0.75rem;
    width: 100%;
  }

  .notice :global(p:last-child) {
    margin-bottom: 0;
  }

  .notice :global(ul),
  .notice :global(ol) {
    width: 100%;
    margin-bottom: 1rem;
  }

  .notice :global(li) {
    width: 100%;
  }

  .notice :global(code) {
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    background: rgba(var(--color-text-rgb), 0.06);
  }

  .notice :global(pre) {
    width: 100%;
    overflow-x: auto;
    margin: 1rem 0;
    background: rgba(var(--color-text-rgb), 0.04);
    border-radius: 0.75rem;
    padding: 1rem;
  }

  /* Responsive text sizing */
  @media (max-width: 640px) {
    .notice h3 {
      font-size: 1.125rem;
    }

    .notice :global(.prose) {
      font-size: 0.875rem;
      line-height: 1.5;
    }
  }
</style>
