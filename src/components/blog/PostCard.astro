---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../utils/date";
import { buildPostPath, getPostSlug } from "../../utils/blog";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const href = buildPostPath(getPostSlug(post));
---

<article class="post-card-modern">
  <a href={href} class="card-link">
    {post.data.image && (
      <div class="image-wrapper">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="post-image"
          loading="lazy"
        />
      </div>
    )}

    <div class="card-content">
      <div class="card-meta">
        {post.data.categories && post.data.categories.length > 0 && (
          <span class="category-badge">{post.data.categories[0]}</span>
        )}
        {post.data.date && (
          <time datetime={post.data.date.toISOString()} class="post-date">
            {formatDate(post.data.date)}
          </time>
        )}
      </div>

      <h3 class="post-title">{post.data.title}</h3>

      {post.data.description && (
        <p class="post-description">{post.data.description}</p>
      )}
    </div>
  </a>
</article>

<style>
  .post-card-modern {
    height: 100%;
    display: flex;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--color-background);
    border: 1px solid rgba(var(--color-text-rgb), 0.08);
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  :global(.dark) .card-link {
    background: var(--color-dark-background-alt);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .card-link:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.1);
    border-color: rgba(var(--color-primary-rgb), 0.3);
  }

  :global(.dark) .card-link:hover {
    box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.3);
    border-color: rgba(var(--color-primary-rgb), 0.5);
  }

  .image-wrapper {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(var(--color-text-rgb), 0.03);
  }

  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card-link:hover .post-image {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .category-badge {
    font-weight: 600;
    color: var(--color-primary);
  }

  .post-date {
    color: var(--color-text-light);
  }

  :global(.dark) .post-date {
    color: var(--color-dark-text-light);
  }

  .post-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
  }

  :global(.dark) .post-title {
    color: var(--color-dark-text);
  }

  .post-description {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.dark) .post-description {
    color: var(--color-dark-text-light);
  }
</style>
