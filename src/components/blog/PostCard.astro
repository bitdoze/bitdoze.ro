---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../utils/date";
import { buildPostPath, getPostSlug } from "../../utils/blog";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const href = buildPostPath(getPostSlug(post));
---

<article class="blog-card">
  <a href={href} class="blog-card__link">
    {
      post.data.image && (
        <div class="blog-card__image-wrap">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="blog-card__image"
            loading="lazy"
          />
        </div>
      )
    }

    <div class="blog-card__body">
      <div class="blog-card__meta">
        {
          post.data.date && (
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
          )
        }
        {
          post.data.categories.length > 0 && (
            <span>{post.data.categories[0]}</span>
          )
        }
      </div>

      <h3 class="blog-card__title">{post.data.title}</h3>

      {
        post.data.description && (
          <p class="blog-card__description">{post.data.description}</p>
        )
      }

      {
        post.data.tags.length > 0 && (
          <div class="blog-card__tags">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="blog-card__tag">#{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>

<style>
  .blog-card {
    height: 100%;
  }

  .blog-card__link {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(var(--color-text-rgb), 0.08);
    border-radius: 1.5rem;
    background:
      linear-gradient(
        180deg,
        rgba(var(--color-background-rgb), 0.98),
        rgba(var(--color-background-alt-rgb), 0.96)
      );
    box-shadow: 0 18px 40px rgba(var(--color-text-rgb), 0.08);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .blog-card__link:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--color-primary-rgb), 0.22);
    box-shadow: 0 24px 48px rgba(var(--color-text-rgb), 0.12);
  }

  .blog-card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .blog-card__title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-text);
  }

  .blog-card__description {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .blog-card__tag {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(var(--color-primary-rgb), 0.1);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
  }
</style>
