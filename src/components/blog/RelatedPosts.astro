---
import { getCollection, type CollectionEntry } from "astro:content";
import { formatDate } from "../../utils/date";
import { buildPostPath, getPostSlug, getRelatedPosts } from "../../utils/blog";

interface Props {
  currentPost: CollectionEntry<"posts">;
}

const { currentPost } = Astro.props;

const posts = await getCollection("posts", ({ data }) => !data.draft);
const currentPostSlug = getPostSlug(currentPost);
const otherPosts = posts.filter((post) => getPostSlug(post) !== currentPostSlug);
const relatedPosts = getRelatedPosts(currentPost, otherPosts, 3);
---

{
  relatedPosts.length > 0 && (
    <section class="related-posts">
      <h2>Articole similare</h2>
      <div class="related-posts__grid">
        {relatedPosts.map((post) => {
          const href = buildPostPath(getPostSlug(post));
          const category = post.data.categories?.[0];

          return (
            <article class="related-post-card">
              <a href={href} class="related-post-card__link">
                {
                  post.data.image && (
                    <div class="related-post-card__image-wrap">
                      <img
                        src={post.data.image}
                        alt={post.data.title}
                        class="related-post-card__image"
                        loading="lazy"
                      />
                    </div>
                  )
                }

                {
                  category && (
                    <span class="related-post-card__badge">{category}</span>
                  )
                }

                <h3>{post.data.title}</h3>

                {
                  post.data.date && (
                    <time datetime={post.data.date.toISOString()}>
                      {formatDate(post.data.date)}
                    </time>
                  )
                }
              </a>
            </article>
          );
        })}
      </div>
    </section>
  )
}

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--color-text-rgb), 0.1);
  }

  .related-posts h2 {
    margin: 0 0 1.5rem;
    font-size: 1.8rem;
    color: var(--color-text);
  }

  .related-posts__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .related-post-card__link {
    display: block;
  }

  .related-post-card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1rem;
    margin-bottom: 0.75rem;
  }

  .related-post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .related-post-card__link:hover .related-post-card__image {
    transform: scale(1.05);
  }

  .related-post-card__badge {
    display: inline-block;
    margin-bottom: 0.55rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: rgba(var(--color-primary-rgb), 0.12);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .related-post-card h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .related-post-card__link:hover h3 {
    color: var(--color-primary);
  }

  .related-post-card time {
    display: block;
    margin-top: 0.5rem;
    color: var(--color-text-light);
    font-size: 0.85rem;
  }
</style>
