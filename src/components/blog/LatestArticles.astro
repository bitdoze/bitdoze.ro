---
import { getCollection } from "astro:content";
import PostCard from "./PostCard.astro";
import { getSortedPosts } from "../../utils/blog";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const latestPosts = getSortedPosts(posts).slice(0, 3);
---

{
  latestPosts.length > 0 && (
    <section class="blog-preview section-padding">
      <div class="container">
        <div class="blog-preview__header">
          <div>
            <p class="blog-preview__eyebrow">Resurse practice</p>
            <h2 class="blog-preview__title">Articole noi pe blog</h2>
            <p class="blog-preview__subtitle">
              Ghiduri în limba română despre web design, SEO, hosting și procese
              digitale care te ajută să iei decizii mai bune.
            </p>
          </div>
          <div class="blog-preview__actions">
            <a href="/blog" class="btn btn-secondary">Vezi toate articolele</a>
            <a href="/search" class="btn btn-primary">Caută în blog</a>
          </div>
        </div>

        <div class="blog-preview__grid">
          {latestPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .blog-preview {
    background:
      radial-gradient(
        circle at top left,
        rgba(var(--color-primary-rgb), 0.08),
        transparent 45%
      ),
      linear-gradient(
        180deg,
        rgba(var(--color-background-alt-rgb), 0.75),
        rgba(var(--color-background-rgb), 1)
      );
  }

  .blog-preview__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .blog-preview__eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-preview__title {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    color: var(--color-text);
  }

  .blog-preview__subtitle {
    max-width: 48rem;
    margin: 0.85rem 0 0;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .blog-preview__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .blog-preview__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
</style>
