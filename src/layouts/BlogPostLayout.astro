---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import RelatedPosts from "../components/blog/RelatedPosts.astro";
import { formatDate } from "../utils/date";
import { buildPostPath, getPostSlug, getRelatedPosts } from "../utils/blog";

interface Props {
  post: CollectionEntry<"posts">;
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, headings = [] } = Astro.props;
const { title, description, image, date, author, tags, categories, canonical } =
  post.data;
const postSlug = getPostSlug(post);
const canonicalPath = canonical || `/blog/${postSlug}/`;
const shareUrl = Astro.site
  ? new URL(canonicalPath, Astro.site).toString()
  : canonicalPath;
const visibleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const encodedTitle = encodeURIComponent(title);
const encodedShareUrl = encodeURIComponent(shareUrl);
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const sidebarRelatedPosts = getRelatedPosts(
  post,
  allPosts.filter((entry) => getPostSlug(entry) !== postSlug),
  3,
);
---

<Layout
  title={title}
  description={description}
  image={image}
  canonical={canonicalPath}
  ogType="article"
  structuredData={{
    type: "article",
    data: {
      headline: title,
      description,
      image,
      datePublished: date?.toISOString(),
      author,
    },
  }}
>
  <section class="blog-post shell section-padding">
    <div class="container">
      <div class="blog-post__intro">
        <a href="/blog" class="blog-post__back">← Toate articolele</a>

        <div class="blog-post__meta">
          {categories.length > 0 && <span class="meta-category">{categories[0]}</span>}
          {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
          {author && <span>· {author}</span>}
        </div>

        <h1>{title}</h1>
        {description && <p class="blog-post__description">{description}</p>}

        {tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map((tag) => (
              <span class="blog-post__tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>

      {image && (
        <div class="blog-post__image-wrap">
          <img src={image} alt={title} class="blog-post__image" />
        </div>
      )}

      <div class="blog-post__body">
        <aside class="blog-post__sidebar">
          {visibleHeadings.length > 0 && (
            <nav class="blog-post__panel" aria-label="Cuprins">
              <div class="blog-post__panel-head">
                <p class="blog-post__panel-label">Cuprins</p>
              </div>
              <ul class="blog-post__toc">
                {visibleHeadings.map((heading) => (
                  <li class:list={["blog-post__toc-item", heading.depth === 3 && "is-sub"]}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          {sidebarRelatedPosts.length > 0 && (
            <div class="blog-post__panel">
              <div class="blog-post__panel-head">
                <p class="blog-post__panel-label">Articole similare</p>
              </div>
              <div class="blog-post__sidebar-related">
                {sidebarRelatedPosts.map((entry) => (
                  <a href={buildPostPath(getPostSlug(entry))} class="blog-post__sidebar-related-item">
                    {entry.data.image && (
                      <div class="blog-post__sidebar-related-image-wrap">
                        <img src={entry.data.image} alt={entry.data.title} class="blog-post__sidebar-related-image" loading="lazy" />
                      </div>
                    )}
                    <h3>{entry.data.title}</h3>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="blog-post__panel">
            <div class="blog-post__panel-head">
              <p class="blog-post__panel-label">Distribuie</p>
            </div>
            <div class="blog-post__share">
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedShareUrl}`} target="_blank" rel="noopener noreferrer">Facebook</a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedShareUrl}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a href={`https://x.com/intent/tweet?url=${encodedShareUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer">X</a>
              <button type="button" class="blog-post__copy" data-copy-link={shareUrl}>Copiază linkul</button>
            </div>
          </div>
        </aside>

        <div class="blog-post__content">
          <slot />
        </div>
      </div>

      <RelatedPosts currentPost={post} />
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("click", async (event) => {
    const button = (event.target instanceof Element)
      ? event.target.closest("[data-copy-link]")
      : null;

    if (!(button instanceof HTMLButtonElement)) return;

    const url = button.dataset.copyLink;
    if (!url || !navigator.clipboard) return;

    await navigator.clipboard.writeText(url);
    const originalText = button.textContent;
    button.textContent = "Link copiat";
    window.setTimeout(() => {
      button.textContent = originalText;
    }, 1800);
  });
</script>

<style>
  .blog-post.shell {
    background-color: var(--color-background);
  }

  :global(.dark) .blog-post.shell {
    background-color: var(--color-dark-background);
  }

  .blog-post__intro {
    max-width: 48rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .blog-post__back {
    display: inline-flex;
    margin-bottom: 2rem;
    color: var(--color-text-light);
    font-weight: 500;
    transition: color 0.2s;
    text-decoration: none;
  }

  .blog-post__back:hover {
    color: var(--color-primary);
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
    font-size: 0.95rem;
    align-items: center;
  }

  .meta-category {
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  .blog-post h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  :global(.dark) .blog-post h1 {
    color: var(--color-dark-text);
  }

  .blog-post__description {
    margin: 1.5rem auto 0;
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-light);
    max-width: 42rem;
  }

  :global(.dark) .blog-post__description {
    color: var(--color-dark-text-light);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .blog-post__tag {
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: rgba(var(--color-text-rgb), 0.05);
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  :global(.dark) .blog-post__tag {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-dark-text-light);
  }

  .blog-post__image-wrap {
    max-width: 64rem;
    margin: 0 auto 3rem;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
  }

  .blog-post__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .blog-post__body {
    display: grid;
    gap: 3rem;
    align-items: start;
    grid-template-columns: minmax(0, 260px) minmax(0, 1fr);
    max-width: 72rem;
    margin: 0 auto;
  }

  .blog-post__sidebar {
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 2rem;
  }

  .blog-post__panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-post__panel-head {
    border-bottom: 1px solid rgba(var(--color-text-rgb), 0.1);
    padding-bottom: 0.5rem;
  }

  :global(.dark) .blog-post__panel-head {
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  .blog-post__panel-label {
    margin: 0;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  :global(.dark) .blog-post__panel-label {
    color: var(--color-dark-text);
  }

  .blog-post__toc {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .blog-post__toc-item a {
    display: block;
    color: var(--color-text-light);
    line-height: 1.4;
    font-size: 0.95rem;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .blog-post__toc-item a:hover {
    color: var(--color-primary);
  }

  .blog-post__toc-item.is-sub {
    padding-left: 1rem;
    border-left: 1px solid rgba(var(--color-text-rgb), 0.1);
  }

  .blog-post__toc-item.is-sub a {
    font-size: 0.9rem;
  }

  .blog-post__sidebar-related {
    display: grid;
    gap: 1.25rem;
  }

  .blog-post__sidebar-related-item {
    display: flex;
    gap: 1rem;
    align-items: center;
    text-decoration: none;
  }

  .blog-post__sidebar-related-image-wrap {
    width: 4rem;
    height: 3rem;
    border-radius: 0.375rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-post__sidebar-related-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-post__sidebar-related-item h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  :global(.dark) .blog-post__sidebar-related-item h3 {
    color: var(--color-dark-text);
  }

  .blog-post__sidebar-related-item:hover h3 {
    color: var(--color-primary);
  }

  .blog-post__share {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blog-post__share a,
  .blog-post__copy {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(var(--color-text-rgb), 0.1);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--color-text-light);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  :global(.dark) .blog-post__share a,
  :global(.dark) .blog-post__copy {
    border-color: rgba(255, 255, 255, 0.1);
    color: var(--color-dark-text-light);
  }

  .blog-post__share a:hover,
  .blog-post__copy:hover {
    background: rgba(var(--color-text-rgb), 0.05);
    color: var(--color-text);
  }

  :global(.dark) .blog-post__share a:hover,
  :global(.dark) .blog-post__copy:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-dark-text);
  }

  .blog-post__content {
    min-width: 0;
    color: var(--color-text);
    line-height: 1.8;
    font-size: 1.125rem;
  }

  :global(.dark) .blog-post__content {
    color: var(--color-dark-text);
  }

  .blog-post__content :global(h2),
  .blog-post__content :global(h3),
  .blog-post__content :global(h4) {
    margin: 3rem 0 1.25rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--color-text);
  }

  :global(.dark) .blog-post__content :global(h2),
  :global(.dark) .blog-post__content :global(h3),
  :global(.dark) .blog-post__content :global(h4) {
    color: var(--color-dark-text);
  }

  .blog-post__content :global(h2) {
    font-size: 2rem;
  }

  .blog-post__content :global(h3) {
    font-size: 1.5rem;
  }

  .blog-post__content :global(p),
  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin: 1.25rem 0;
    color: var(--color-text-light);
  }

  :global(.dark) .blog-post__content :global(p),
  :global(.dark) .blog-post__content :global(ul),
  :global(.dark) .blog-post__content :global(ol) {
    color: var(--color-dark-text-light);
  }

  .blog-post__content :global(a:not(.not-prose)) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s;
  }

  .blog-post__content :global(a:not(.not-prose):hover) {
    text-decoration-color: var(--color-primary);
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    padding-left: 1.5rem;
  }

  .blog-post__content :global(li) {
    margin: 0.5rem 0;
  }

  .blog-post__content :global(pre) {
    margin: 2rem 0;
    padding: 1.25rem;
    border-radius: 0.5rem;
    background: #1e1e1e !important;
    overflow-x: auto;
    font-size: 0.9rem;
  }

  .blog-post__content :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  .blog-post__content :global(p code) {
    background: rgba(var(--color-text-rgb), 0.05);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.9em;
    color: var(--color-text);
  }

  :global(.dark) .blog-post__content :global(p code) {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-dark-text);
  }

  .blog-post__content :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid var(--color-primary);
    background: rgba(var(--color-primary-rgb), 0.05);
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: var(--color-text);
  }

  :global(.dark) .blog-post__content :global(blockquote) {
    color: var(--color-dark-text);
  }

  .blog-post__content :global(img) {
    border-radius: 0.5rem;
    margin: 2rem 0;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 960px) {
    .blog-post__body {
      grid-template-columns: 1fr;
    }

    .blog-post__sidebar {
      position: static;
      order: 2;
      margin-top: 3rem;
      border-top: 1px solid rgba(var(--color-text-rgb), 0.1);
      padding-top: 3rem;
    }

    :global(.dark) .blog-post__sidebar {
      border-top-color: rgba(255, 255, 255, 0.1);
    }
  }
</style>
